// RUN: not ptoas --pto-arch=a3 --mlir-print-ir-after=pto-materialize-tile-handles %s -o /dev/null 2>&1 | FileCheck %s

module {
  func.func @control_flow_result_tile_materialization(%cond: i1) {
    %lhs = pto.alloc_tile : !pto.tile_buf<vec, 16x16xf16>
    %rhs = pto.alloc_tile : !pto.tile_buf<vec, 16x16xf16>
    %dst = pto.alloc_tile : !pto.tile_buf<vec, 16x16xf16>

    %selected = scf.if %cond -> (!pto.tile_buf<vec, 16x16xf16>) {
      scf.yield %lhs : !pto.tile_buf<vec, 16x16xf16>
    } else {
      scf.yield %rhs : !pto.tile_buf<vec, 16x16xf16>
    }

    pto.tadd ins(%selected, %selected
      : !pto.tile_buf<vec, 16x16xf16>, !pto.tile_buf<vec, 16x16xf16>)
      outs(%dst : !pto.tile_buf<vec, 16x16xf16>)
    return
  }
}

// CHECK: cannot materialize tile handle for local memref
// CHECK: control-flow result 'scf.if' cannot carry a local memref into tile materialization
