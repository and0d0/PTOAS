// RUN: not pto-test-opt %s -vmi-layout-assignment 2>&1 | FileCheck %s

module {
  func.func @vmi_fma_integer_invalid(
      %lhs: !pto.vmi.vreg<64xi32>,
      %rhs: !pto.vmi.vreg<64xi32>,
      %acc: !pto.vmi.vreg<64xi32>) -> !pto.vmi.vreg<64xi32> {
    %out = pto.vmi.fma %lhs, %rhs, %acc
        : !pto.vmi.vreg<64xi32>, !pto.vmi.vreg<64xi32>,
          !pto.vmi.vreg<64xi32> -> !pto.vmi.vreg<64xi32>
    return %out : !pto.vmi.vreg<64xi32>
  }
}

// CHECK: 'pto.vmi.fma' op requires floating-point-like VMI element type
