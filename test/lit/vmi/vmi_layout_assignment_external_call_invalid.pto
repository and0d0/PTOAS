// RUN: not pto-test-opt %s -vmi-layout-assignment 2>&1 | FileCheck %s

module {
  func.func private @external(!pto.vmi.vreg<128xf32>)
      -> !pto.vmi.vreg<128xf32>

  func.func @caller(%x: !pto.vmi.vreg<128xf32>) {
    %r = call @external(%x)
        : (!pto.vmi.vreg<128xf32>) -> !pto.vmi.vreg<128xf32>
    %sum = pto.vmi.addf %r, %r
        : !pto.vmi.vreg<128xf32>, !pto.vmi.vreg<128xf32>
        -> !pto.vmi.vreg<128xf32>
    return
  }
}

// CHECK: VMI-LAYOUT-CONTRACT: VMI typed function declaration requires an explicit external ABI materialization plan
