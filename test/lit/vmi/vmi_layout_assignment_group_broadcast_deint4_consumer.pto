// RUN: pto-test-opt %s -vmi-mask-granularity-assignment -vmi-layout-assignment | FileCheck %s

module {
  func.func @vmi_layout_assignment_group_broadcast_deint4_consumer(
      %sum: !pto.vmi.vreg<2xf32, #pto.vmi.layout<num_groups = 2, slots = 1>>,
      %src: !pto.ptr<f8E4M3FN, ub>,
      %dst: !pto.ptr<f32, ub>,
      %off: index,
      %stride: index) {
    %x8 = pto.vmi.group_load %src[%off], %stride {num_groups = 2}
        : !pto.ptr<f8E4M3FN, ub> -> !pto.vmi.vreg<512xf8E4M3FN>
    %x = pto.vmi.extf %x8
        : !pto.vmi.vreg<512xf8E4M3FN> -> !pto.vmi.vreg<512xf32>
    %scale = pto.vmi.group_broadcast %sum {num_groups = 2}
        : !pto.vmi.vreg<2xf32, #pto.vmi.layout<num_groups = 2, slots = 1>>
        -> !pto.vmi.vreg<512xf32>
    %out = pto.vmi.mulf %scale, %x
        : !pto.vmi.vreg<512xf32>, !pto.vmi.vreg<512xf32>
        -> !pto.vmi.vreg<512xf32>
    pto.vmi.group_store %out, %dst[%off], %stride {num_groups = 2}
        : !pto.vmi.vreg<512xf32>, !pto.ptr<f32, ub>
    return
  }
}

// CHECK-LABEL: func.func @vmi_layout_assignment_group_broadcast_deint4_consumer(
// CHECK-SAME: %arg0: !pto.vmi.vreg<2xf32, #pto.vmi.layout<num_groups = 2, slots = 1>>
// CHECK: %[[X8:.*]] = pto.vmi.group_load
// CHECK-SAME: -> !pto.vmi.vreg<512xf8E4M3FN, #pto.vmi.layout<contiguous>>
// CHECK: %[[X:.*]] = pto.vmi.extf %[[X8]]
// CHECK-SAME: -> !pto.vmi.vreg<512xf32, #pto.vmi.layout<deinterleaved = 4>>
// CHECK: %[[SCALE:.*]] = pto.vmi.group_broadcast %arg0
// CHECK-SAME: -> !pto.vmi.vreg<512xf32, #pto.vmi.layout<deinterleaved = 4>>
// CHECK: %[[OUT:.*]] = pto.vmi.mulf %[[SCALE]], %[[X]]
// CHECK-SAME: -> !pto.vmi.vreg<512xf32, #pto.vmi.layout<deinterleaved = 4>>
// CHECK: %[[OUT_D2:.*]] = pto.vmi.ensure_layout %[[OUT]]
// CHECK-SAME: -> !pto.vmi.vreg<512xf32, #pto.vmi.layout<deinterleaved = 2>>
// CHECK: pto.vmi.group_store %[[OUT_D2]]
