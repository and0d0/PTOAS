// RUN: pto-test-opt %s -vmi-layout-assignment -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_layout_assignment_group_load_block8_truncf(
      %src: !pto.ptr<f32, ub>,
      %sum_dst: !pto.ptr<f32, ub>,
      %dense_dst: !pto.ptr<f16, ub>,
      %off: index) {
    %c1 = arith.constant 1 : index
    %stride24 = arith.constant 24 : index
    %c128 = arith.constant 128 : index
    %mask = pto.vmi.create_mask %c128 : index -> !pto.vmi.mask<128xpred>
    %x = pto.vmi.group_load %src[%off], %stride24 {num_groups = 8}
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<128xf32>
    %sum = pto.vmi.group_reduce_addf %x, %mask
        {num_groups = 8, reassoc}
        : !pto.vmi.vreg<128xf32>, !pto.vmi.mask<128xpred>
        -> !pto.vmi.vreg<8xf32>
    pto.vmi.group_store %sum, %sum_dst[%off], %c1 {num_groups = 8}
        : !pto.vmi.vreg<8xf32>, !pto.ptr<f32, ub>
    %h = pto.vmi.truncf %x
        : !pto.vmi.vreg<128xf32> -> !pto.vmi.vreg<128xf16>
    pto.vmi.store %h, %dense_dst[%off]
        : !pto.vmi.vreg<128xf16>, !pto.ptr<f16, ub>
    return
  }
}

// CHECK-LABEL: func.func @vmi_layout_assignment_group_load_block8_truncf(
// CHECK: pto.vsldb
// CHECK: pto.vcgadd
// CHECK: pto.vintlv
// CHECK: pto.vdintlv
// CHECK: pto.vcvt
// CHECK: pto.vsts
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
