// RUN: not pto-test-opt %s -vmi-mask-granularity-assignment -vmi-layout-assignment -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_layout_assignment_group_slot_broadcast_partial_packet_invalid(
      %src: !pto.ptr<f16, ub>, %off: index) -> !pto.vmi.vreg<64xf16> {
    %c1 = arith.constant 1 : index
    %slots = pto.vmi.group_slot_load %src[%off], %c1 {num_groups = 4}
        : !pto.ptr<f16, ub> -> !pto.vmi.vreg<4xf16>
    %out = pto.vmi.group_broadcast %slots {num_groups = 4}
        : !pto.vmi.vreg<4xf16> -> !pto.vmi.vreg<64xf16>
    return %out : !pto.vmi.vreg<64xf16>
  }
}

// CHECK: VMI{{-}}UNSUPPORTED{{:}} pto.vmi.group_broadcast requires full source chunks
// CHECK-SAME: requires full source group-slot chunks
// CHECK-NOT: E2B_B16
