module {
  func.func @vmi_layout_factor_invalid(
      %arg0: !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 3>>) {
    return
  }
}

// CHECK: #pto.vmi.layout<deinterleaved = 3> expected factor to be 2 or 4

