module {
  func.func @vmi_block_layout_factor_invalid(
      %arg0: !pto.vmi.vreg<128xf32, #pto.vmi.layout<block_deinterleaved = 3>>) {
    return
  }
}

// CHECK: #pto.vmi.layout<block_deinterleaved = 3> expected factor to be 2 or 4

// -----

module {
  func.func @vmi_layout_block_elems_removed(
      %arg0: !pto.vmi.vreg<128xf32,
          #pto.vmi.layout<deinterleaved = 2, block_elems = 8>>) {
    return
  }
}

