// RUN: not pto-test-opt %s -pto-validate-vmi-layout-ir 2>&1 | FileCheck %s

module {
  func.func @vmi_layout_gate_group_reduce_slots1_recipe_invalid(
      %source: !pto.vmi.vreg<256xf32, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<256xb32, #pto.vmi.layout<contiguous>>) {
    // CHECK: VMI-LAYOUT-CONTRACT: pto.vmi.group_reduce_addf has no registered group_slots local recipe
    // CHECK-SAME: stable group_reduce_add slots=1 recipes support group sizes that are multiples of one physical chunk
    // CHECK: note: see current operation: %{{.*}} = "pto.vmi.group_reduce_addf"
    %out = pto.vmi.group_reduce_addf %source, %mask
        {num_groups = 8, reassoc}
        : !pto.vmi.vreg<256xf32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<256xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<256xf32, #pto.vmi.layout<num_groups = 8, slots = 1>>
    return
  }
}
