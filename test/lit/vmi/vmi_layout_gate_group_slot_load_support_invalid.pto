// RUN: not pto-test-opt %s -pto-validate-vmi-layout-ir 2>&1 | FileCheck %s

module {
  func.func @vmi_layout_gate_group_slot_load_support_invalid(
      %src: !pto.ptr<f32, ub>, %off: index, %stride: index) {
    // CHECK: VMI-LAYOUT-CONTRACT: pto.vmi.group_slot_load has no registered layout support
    // CHECK-SAME: result layout does not match a supported group_slot_load table row
    // CHECK: note: see current operation: %{{.*}} = "pto.vmi.group_slot_load"
    %out = pto.vmi.group_slot_load %src[%off], %stride
        {num_groups = 8}
        : !pto.ptr<f32, ub>
        -> !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 2>>
    return
  }
}
