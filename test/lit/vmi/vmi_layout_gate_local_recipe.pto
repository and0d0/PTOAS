// RUN: pto-test-opt %s -pto-validate-vmi-layout-ir | FileCheck %s

module {
  func.func @vmi_layout_gate_local_recipe(
      %source: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>) {
    %out = pto.vmi.group_reduce_addf %source, %mask {num_groups = 8, reassoc}
        : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xf32, #pto.vmi.layout<num_groups = 8, slots = 8>>
    return
  }
}

// CHECK-LABEL: func.func @vmi_layout_gate_local_recipe(
// CHECK: pto.vmi.group_reduce_addf
