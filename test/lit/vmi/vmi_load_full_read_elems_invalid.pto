// RUN: not pto-test-opt %s -vmi-layout-assignment 2>&1 | FileCheck %s

module {
  func.func @vmi_load_full_read_elems_invalid(%src: !pto.ptr<f32, ub>) {
    %c0 = arith.constant 0 : index
    %value = pto.vmi.load %src[%c0] {full_read_elems = 0}
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<100xf32>
    return
  }
}

// CHECK: 'pto.vmi.load' op requires full_read_elems to be positive
