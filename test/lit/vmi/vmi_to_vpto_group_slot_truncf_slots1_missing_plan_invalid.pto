// RUN: not pto-test-opt %s -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_to_vpto_group_slot_truncf_slots1_missing_plan_invalid(
      %source: !pto.vmi.vreg<512xf32, #pto.vmi.layout<num_groups = 8, slots = 1>>) {
    %narrow = pto.vmi.truncf %source
        : !pto.vmi.vreg<512xf32, #pto.vmi.layout<num_groups = 8, slots = 1>>
        -> !pto.vmi.vreg<512xf16, #pto.vmi.layout<num_groups = 8, slots = 1>>
    "pto.vmi.unpack"(%narrow)
        : (!pto.vmi.vreg<512xf16, #pto.vmi.layout<num_groups = 8, slots = 1>>)
        -> (!pto.vreg<128xf16>, !pto.vreg<128xf16>, !pto.vreg<128xf16>,
            !pto.vreg<128xf16>, !pto.vreg<128xf16>, !pto.vreg<128xf16>,
            !pto.vreg<128xf16>, !pto.vreg<128xf16>)
    return
  }
}

// CHECK: VMI-UNSUPPORTED:
// CHECK: pto.vmi.truncf supports only
// CHECK: requires vmi.selected_plan selected by vmi-layout-assignment
