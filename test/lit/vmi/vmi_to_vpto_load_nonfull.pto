// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_to_vpto_load_nonfull(
      %src: !pto.ptr<f32, ub>, %offset: index)
      -> (!pto.vreg<64xf32>) {
    %value = pto.vmi.load %src[%offset]
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<4xf32, #pto.vmi.layout<contiguous>>
    %part = "pto.vmi.unpack"(%value)
        : (!pto.vmi.vreg<4xf32, #pto.vmi.layout<contiguous>>) -> !pto.vreg<64xf32>
    return %part : !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_load_nonfull(
// CHECK: pto.vlds %arg0[%arg1] : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
