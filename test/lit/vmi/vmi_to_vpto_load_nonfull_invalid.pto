// RUN: not pto-test-opt %s -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_to_vpto_load_nonfull_invalid(
      %src: !pto.ptr<f32, ub>, %offset: index)
      -> (!pto.vreg<64xf32>) {
    %value = pto.vmi.load %src[%offset]
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<4xf32, #pto.vmi.layout<contiguous>>
    %part = "pto.vmi.unpack"(%value)
        : (!pto.vmi.vreg<4xf32, #pto.vmi.layout<contiguous>>) -> !pto.vreg<64xf32>
    return %part : !pto.vreg<64xf32>
  }
}

// CHECK: VMI{{-}}UNSUPPORTED{{:}} pto.vmi.load requires full physical chunks without padding lanes or a statically safe full-read footprint
// CHECK-SAME: safe-read proof failed: requires constant index offset
// CHECK-SAME: fallback decision: partial/tail read needs a scratch, guarded, or true masked/non-faulting load fallback
// CHECK-SAME: scratch memory fallback resource allocation is not implemented
// CHECK-SAME: guarded memory fallback control-flow lowering is not implemented
