// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_to_vpto_load_nonfull_memref(%src: memref<100xf32, #pto.address_space<vec>>)
      -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>) {
    %c0 = arith.constant 0 : index
    %value = pto.vmi.load %src[%c0]
        : memref<100xf32, #pto.address_space<vec>> -> !pto.vmi.vreg<100xf32, #pto.vmi.layout<contiguous>>
    %p0, %p1 = "pto.vmi.unpack"(%value)
        : (!pto.vmi.vreg<100xf32, #pto.vmi.layout<contiguous>>)
        -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>)
    return %p0, %p1 : !pto.vreg<64xf32>, !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_load_nonfull_memref(
// CHECK: %[[C0:.*]] = arith.constant 0 : index
// CHECK: pto.vlds %arg0[%[[C0]]] : memref<100xf32, #pto.address_space<vec>> -> !pto.vreg<64xf32>
// CHECK: %[[C64:.*]] = arith.constant 64 : index
// CHECK: %[[OFF1:.*]] = arith.addi %[[C0]], %[[C64]] : index
// CHECK: pto.vlds %arg0[%[[OFF1]]] : memref<100xf32, #pto.address_space<vec>> -> !pto.vreg<64xf32>
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
