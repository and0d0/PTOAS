// RUN: not pto-test-opt %s -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_to_vpto_load_safe_tail_memref_invalid(%src: memref<100xf32>)
      -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>) {
    %c0 = arith.constant 0 : index
    %value = pto.vmi.load %src[%c0]
        : memref<100xf32> -> !pto.vmi.vreg<100xf32, #pto.vmi.layout<contiguous>>
    %p0, %p1 = "pto.vmi.unpack"(%value)
        : (!pto.vmi.vreg<100xf32, #pto.vmi.layout<contiguous>>)
        -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>)
    return %p0, %p1 : !pto.vreg<64xf32>, !pto.vreg<64xf32>
  }
}

// CHECK: VMI{{-}}UNSUPPORTED{{:}} pto.vmi.load requires full physical chunks without padding lanes or a statically safe full-read footprint
// CHECK-SAME: safe-read proof failed: full physical read footprint [0, 128) exceeds static memref element count 100
