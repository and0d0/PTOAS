// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_to_vpto_load_safe_tail_memref_negative_offset(%src: memref<132xf32, #pto.address_space<vec>>)
      -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>) {
    %cm1 = arith.constant -1 : index
    %value = pto.vmi.load %src[%cm1]
        : memref<132xf32, #pto.address_space<vec>> -> !pto.vmi.vreg<100xf32, #pto.vmi.layout<contiguous>>
    %p0, %p1 = "pto.vmi.unpack"(%value)
        : (!pto.vmi.vreg<100xf32, #pto.vmi.layout<contiguous>>)
        -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>)
    return %p0, %p1 : !pto.vreg<64xf32>, !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_load_safe_tail_memref_negative_offset(
// CHECK: pto.vlds
// CHECK: pto.vlds
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
