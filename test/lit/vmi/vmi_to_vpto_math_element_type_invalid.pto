// RUN: not pto-test-opt %s -split-input-file -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_to_vpto_addf_f8_invalid(
      %lhs: !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>,
      %rhs: !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>) {
    %out = pto.vmi.addf %lhs, %rhs
        : !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: 'pto.vmi.addf' op requires f16, bf16, or f32 VMI element type

// -----

module {
  func.func @vmi_to_vpto_divf_bf16_invalid(
      %lhs: !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>,
      %rhs: !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>) {
    %out = pto.vmi.divf %lhs, %rhs
        : !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: 'pto.vmi.divf' op requires f16 or f32 VMI element type

// -----

module {
  func.func @vmi_to_vpto_sqrt_bf16_invalid(
      %source: !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>) {
    %out = pto.vmi.sqrt %source
        : !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: 'pto.vmi.sqrt' op requires f16 or f32 VMI element type

// -----

module {
  func.func @vmi_to_vpto_exp_f8_invalid(
      %source: !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>) {
    %out = pto.vmi.exp %source
        : !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: 'pto.vmi.exp' op requires f16 or f32 VMI element type

// -----

module {
  func.func @vmi_to_vpto_negf_bf16_invalid(
      %source: !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>) {
    %out = pto.vmi.negf %source
        : !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: 'pto.vmi.negf' op requires f16 or f32 VMI element type

// -----

module {
  func.func @vmi_to_vpto_ln_bf16_invalid(
      %source: !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>) {
    %out = pto.vmi.ln %source
        : !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: 'pto.vmi.ln' op requires f16 or f32 VMI element type

// -----

module {
  func.func @vmi_to_vpto_absf_bf16_invalid(
      %source: !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>) {
    %out = pto.vmi.absf %source
        : !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: 'pto.vmi.absf' op requires f16 or f32 VMI element type

// -----

module {
  func.func @vmi_to_vpto_absi_unsigned_invalid(
      %source: !pto.vmi.vreg<128xui16, #pto.vmi.layout<contiguous>>) {
    %out = pto.vmi.absi %source
        : !pto.vmi.vreg<128xui16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<128xui16, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: 'pto.vmi.absi' op requires signless or signed i8, i16, or i32 VMI element type
