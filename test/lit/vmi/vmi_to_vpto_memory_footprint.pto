// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_to_vpto_load_deint2_f16_no_widen(
      %src: !pto.ptr<f16, ub>, %offset: index)
      -> (!pto.vreg<128xf16>, !pto.vreg<128xf16>) {
    %value = pto.vmi.load %src[%offset]
        : !pto.ptr<f16, ub> -> !pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 2>>
    %p0, %p1 = "pto.vmi.unpack"(%value)
        : (!pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 2>>)
        -> (!pto.vreg<128xf16>, !pto.vreg<128xf16>)
    return %p0, %p1 : !pto.vreg<128xf16>, !pto.vreg<128xf16>
  }

  func.func @vmi_to_vpto_store_deint2_f16_no_widen(
      %value: !pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 2>>,
      %dst: !pto.ptr<f16, ub>, %offset: index) {
    pto.vmi.store %value, %dst[%offset]
        : !pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 2>>, !pto.ptr<f16, ub>
    return
  }

  func.func @vmi_to_vpto_load_deint4_f16_64_no_widen(
      %src: !pto.ptr<f16, ub>, %offset: index)
      -> (!pto.vreg<128xf16>, !pto.vreg<128xf16>,
          !pto.vreg<128xf16>, !pto.vreg<128xf16>) {
    %value = pto.vmi.load %src[%offset]
        : !pto.ptr<f16, ub> -> !pto.vmi.vreg<64xf16, #pto.vmi.layout<deinterleaved = 4>>
    %p0, %p1, %p2, %p3 = "pto.vmi.unpack"(%value)
        : (!pto.vmi.vreg<64xf16, #pto.vmi.layout<deinterleaved = 4>>)
        -> (!pto.vreg<128xf16>, !pto.vreg<128xf16>,
            !pto.vreg<128xf16>, !pto.vreg<128xf16>)
    return %p0, %p1, %p2, %p3
        : !pto.vreg<128xf16>, !pto.vreg<128xf16>,
          !pto.vreg<128xf16>, !pto.vreg<128xf16>
  }

  func.func @vmi_to_vpto_load_deint4_f16_no_widen(
      %src: !pto.ptr<f16, ub>, %offset: index)
      -> (!pto.vreg<128xf16>, !pto.vreg<128xf16>,
          !pto.vreg<128xf16>, !pto.vreg<128xf16>) {
    %value = pto.vmi.load %src[%offset]
        : !pto.ptr<f16, ub> -> !pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 4>>
    %p0, %p1, %p2, %p3 = "pto.vmi.unpack"(%value)
        : (!pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 4>>)
        -> (!pto.vreg<128xf16>, !pto.vreg<128xf16>,
            !pto.vreg<128xf16>, !pto.vreg<128xf16>)
    return %p0, %p1, %p2, %p3
        : !pto.vreg<128xf16>, !pto.vreg<128xf16>,
          !pto.vreg<128xf16>, !pto.vreg<128xf16>
  }

  func.func @vmi_to_vpto_load_deint4_f16_256_no_widen(
      %src: !pto.ptr<f16, ub>, %offset: index)
      -> (!pto.vreg<128xf16>, !pto.vreg<128xf16>,
          !pto.vreg<128xf16>, !pto.vreg<128xf16>) {
    %value = pto.vmi.load %src[%offset]
        : !pto.ptr<f16, ub> -> !pto.vmi.vreg<256xf16, #pto.vmi.layout<deinterleaved = 4>>
    %p0, %p1, %p2, %p3 = "pto.vmi.unpack"(%value)
        : (!pto.vmi.vreg<256xf16, #pto.vmi.layout<deinterleaved = 4>>)
        -> (!pto.vreg<128xf16>, !pto.vreg<128xf16>,
            !pto.vreg<128xf16>, !pto.vreg<128xf16>)
    return %p0, %p1, %p2, %p3
        : !pto.vreg<128xf16>, !pto.vreg<128xf16>,
          !pto.vreg<128xf16>, !pto.vreg<128xf16>
  }

  func.func @vmi_to_vpto_store_deint4_f16_64_no_widen(
      %value: !pto.vmi.vreg<64xf16, #pto.vmi.layout<deinterleaved = 4>>,
      %dst: !pto.ptr<f16, ub>, %offset: index) {
    pto.vmi.store %value, %dst[%offset]
        : !pto.vmi.vreg<64xf16, #pto.vmi.layout<deinterleaved = 4>>, !pto.ptr<f16, ub>
    return
  }

  func.func @vmi_to_vpto_store_deint4_f16_no_widen(
      %value: !pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 4>>,
      %dst: !pto.ptr<f16, ub>, %offset: index) {
    pto.vmi.store %value, %dst[%offset]
        : !pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 4>>, !pto.ptr<f16, ub>
    return
  }

  func.func @vmi_to_vpto_store_deint4_f16_256_no_widen(
      %value: !pto.vmi.vreg<256xf16, #pto.vmi.layout<deinterleaved = 4>>,
      %dst: !pto.ptr<f16, ub>, %offset: index) {
    pto.vmi.store %value, %dst[%offset]
        : !pto.vmi.vreg<256xf16, #pto.vmi.layout<deinterleaved = 4>>, !pto.ptr<f16, ub>
    return
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_load_deint2_f16_no_widen(
// CHECK-NOT: pto.vldsx2
// CHECK: %[[LOAD:.*]] = pto.vlds %arg0[%arg1]
// CHECK: %[[LOW:.*]], %[[HIGH:.*]] = pto.vdintlv %[[LOAD]], %[[LOAD]]
// CHECK: return %[[LOW]], %[[HIGH]]
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast

// CHECK-LABEL: func.func @vmi_to_vpto_store_deint2_f16_no_widen(
// CHECK-NOT: pto.vstsx2
// CHECK: %[[LOW:.*]], %[[HIGH:.*]] = pto.vintlv %arg0, %arg1
// CHECK: %[[MASK:.*]] = pto.pset_b16 "PAT_ALL"
// CHECK: pto.vsts %[[LOW]], %arg2[%arg3], %[[MASK]]
// CHECK-NOT: pto.vsts %[[HIGH]]
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast

// CHECK-LABEL: func.func @vmi_to_vpto_load_deint4_f16_64_no_widen(
// CHECK-NOT: pto.vldsx2
// CHECK: %[[LOAD64:.*]] = pto.vlds %arg0[%arg1]
// CHECK-NOT: pto.vldsx2
// CHECK-COUNT-4: pto.vdintlv
// CHECK: return
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast

// CHECK-LABEL: func.func @vmi_to_vpto_load_deint4_f16_no_widen(
// CHECK-NOT: pto.vldsx2
// CHECK: %[[LOAD:.*]] = pto.vlds %arg0[%arg1]
// CHECK-NOT: pto.vldsx2
// CHECK-COUNT-4: pto.vdintlv
// CHECK: return
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast

// CHECK-LABEL: func.func @vmi_to_vpto_load_deint4_f16_256_no_widen(
// CHECK-NOT: pto.vldsx2
// CHECK-COUNT-2: pto.vlds
// CHECK-NOT: pto.vldsx2
// CHECK-COUNT-4: pto.vdintlv
// CHECK: return
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast

// CHECK-LABEL: func.func @vmi_to_vpto_store_deint4_f16_64_no_widen(
// CHECK-NOT: pto.vstsx2
// CHECK-COUNT-4: pto.vintlv
// CHECK: %[[C64:.*]] = arith.constant 64 : i32
// CHECK: %[[MASK64:.*]], {{.*}} = pto.plt_b16 %[[C64]]
// CHECK: pto.vsts {{.*}}, %arg4[%arg5], %[[MASK64]]
// CHECK-NOT: pto.vsts
// CHECK: return
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast

// CHECK-LABEL: func.func @vmi_to_vpto_store_deint4_f16_no_widen(
// CHECK-NOT: pto.vstsx2
// CHECK-COUNT-4: pto.vintlv
// CHECK: %[[MASK4:.*]] = pto.pset_b16 "PAT_ALL"
// CHECK: pto.vsts {{.*}}, %arg4[%arg5], %[[MASK4]]
// CHECK-NOT: pto.vsts
// CHECK: return
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast

// CHECK-LABEL: func.func @vmi_to_vpto_store_deint4_f16_256_no_widen(
// CHECK-NOT: pto.vstsx2
// CHECK-COUNT-4: pto.vintlv
// CHECK-COUNT-2: pto.vsts
// CHECK: return
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
