// RUN: not pto-test-opt %s -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_to_vpto_reduce_maxf_tail_invalid(
      %source: !pto.vmi.vreg<65xf32, #pto.vmi.layout<contiguous>>,
      %init: !pto.vmi.vreg<1xf32, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<65xb32, #pto.vmi.layout<contiguous>>) {
    %out = pto.vmi.reduce_maxf %source, %init, %mask
        : !pto.vmi.vreg<65xf32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<1xf32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<65xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<1xf32, #pto.vmi.layout<contiguous>>
    %part = "pto.vmi.unpack"(%out)
        : (!pto.vmi.vreg<1xf32, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<64xf32>
    return
  }
}

// CHECK: VMI{{.*}} pto.vmi.reduce_maxf lowers through pto.vcmax only
// CHECK-SAME: requires full source physical chunks
