// RUN: not pto-test-opt %s -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_to_vpto_unsupported_op_invalid(
      %a: !pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>>) {
    %shuffled = "pto.vmi.shuffle"(%a) {
      indices = array<i64: 1, 2, 3, 4>
    } : (!pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>>)
        -> !pto.vmi.vreg<4xf32, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: VMI{{-}}UNSUPPORTED{{:}} pto.vmi.shuffle requires physical chunk forwarding or lane0 splat or vci-materializable vselr indices
// CHECK-SAME: forwarding:
// CHECK-SAME: lane0 splat:
// CHECK-SAME: vselr:
