// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

module {
  func.func @vmi_truncf_rounding_token_invalid(
      %source: !pto.vmi.vreg<256xf32>) {
    %result = pto.vmi.truncf %source {rounding = "R"}
        : !pto.vmi.vreg<256xf32> -> !pto.vmi.vreg<256x!pto.hif8>
    return
  }
}

// truncf shares vcvt's rounding-token parser, so "Z" is also accepted even
// though this test still exercises the legacy truncf surface spelling.
// CHECK: rounding attr must be A, H, or Z
