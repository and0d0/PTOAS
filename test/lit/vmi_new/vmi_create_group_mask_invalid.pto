// RUN: not pto-test-opt %s 2>&1 | FileCheck %s

module {
  func.func @vmi_create_group_mask_lane_count_invalid() {
    %c12 = arith.constant 12 : index
    // CHECK: pto.vmi.create_group_mask
    // CHECK-SAME: requires result lane count to equal num_groups * group_size
    %mask = pto.vmi.create_group_mask %c12 {num_groups = 8, group_size = 16}
        : index -> !pto.vmi.mask<127xpred>
    return
  }
}
