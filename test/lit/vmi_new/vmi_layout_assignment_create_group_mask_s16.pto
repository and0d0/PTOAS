// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment | FileCheck %s --check-prefix=ASSIGN
// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment -vmi-to-vpto | FileCheck %s --check-prefix=LOWER

module {
  func.func @vmi_layout_assignment_create_group_mask_s16(
      %base: !pto.ptr<f32, ub>, %dst: !pto.ptr<f32, ub>, %off: index) {
    %c1 = arith.constant 1 : index
    %c12 = arith.constant 12 : index
    %c16 = arith.constant 16 : index
    %x = pto.vmi.vload %base[%off], %c16 {group = 8}
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<128xf32>
    %mask = pto.vmi.create_group_mask %c12 {num_groups = 8, group_size = 16}
        : index -> !pto.vmi.mask<128xpred>
    %sum = pto.vmi.vcadd %x, %mask {group = 8, reassoc}
        : !pto.vmi.vreg<128xf32>, !pto.vmi.mask<128xpred>
        -> !pto.vmi.vreg<8xf32>
    pto.vmi.vstore %sum, %dst[%off], %c1 {group = 8}
        : !pto.vmi.vreg<8xf32>, !pto.ptr<f32, ub>
    return
  }
}

// ASSIGN-LABEL: func.func @vmi_layout_assignment_create_group_mask_s16(
// ASSIGN: %[[RAW:.*]] = pto.vmi.group_load
// ASSIGN-SAME: -> !pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>>
// ASSIGN: %[[MASK0:.*]] = pto.vmi.create_group_mask
// ASSIGN-SAME: -> !pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>
// ASSIGN: %[[X:.*]] = pto.vmi.ensure_layout %[[RAW]]
// ASSIGN-SAME: !pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>>
// ASSIGN-SAME: -> !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>
// ASSIGN: %[[SUM:.*]] = pto.vmi.group_reduce_addf %[[X]], %[[MASK0]]
// ASSIGN-SAME: -> !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 8>>

// LOWER-LABEL: func.func @vmi_layout_assignment_create_group_mask_s16(
// LOWER-COUNT-2: pto.vlds
// LOWER-NOT: pto.vmi.
