// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment | FileCheck %s --check-prefix=ASSIGN
// RUN: not pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment -vmi-to-vpto 2>&1 | FileCheck %s --check-prefix=LOWERERR

module {
  func.func @vmi_layout_assignment_group_load_s16_stride_store(
      %base: !pto.ptr<f32, ub>,
      %mask: !pto.vmi.mask<128xpred>,
      %dst: !pto.ptr<f32, ub>,
      %off: index) {
    %c1 = arith.constant 1 : index
    %stride24 = arith.constant 24 : index
    %x = pto.vmi.vload %base[%off], %stride24 {group = 8}
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<128xf32>
    %sum = pto.vmi.vcadd %x, %mask
        {group = 8, reassoc}
        : !pto.vmi.vreg<128xf32>, !pto.vmi.mask<128xpred>
        -> !pto.vmi.vreg<8xf32>
    pto.vmi.vstore %sum, %dst[%off], %c1 {group = 8}
        : !pto.vmi.vreg<8xf32>, !pto.ptr<f32, ub>
    return
  }
}

// ASSIGN-LABEL: func.func @vmi_layout_assignment_group_load_s16_stride_store(
// ASSIGN: %[[RAW:.*]] = pto.vmi.group_load
// ASSIGN-SAME: -> !pto.vmi.vreg<128xf32, #pto.vmi.layout<block_deinterleaved = 2>>
// ASSIGN: %[[MASK:.*]] = pto.vmi.ensure_mask_layout
// ASSIGN-SAME: -> !pto.vmi.mask<128xb32, #pto.vmi.layout<block_deinterleaved = 2>>
// ASSIGN: %[[SUM:.*]] = pto.vmi.group_reduce_addf %[[RAW]], %[[MASK]]
// ASSIGN-SAME: -> !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 8>>
// ASSIGN: pto.vmi.group_store %[[SUM]]

// LOWERERR: failed to legalize operation 'pto.vmi.ensure_mask_layout'
// LOWERERR: VMI{{-}}RESIDUAL{{-}}OP: failed to convert all VMI ops/types to VPTO
