// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-pre-assignment-combine -vmi-mask-granularity-assignment -vmi-layout-assignment -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_layout_assignment_group_slot_broadcast_load_brc_b32(
      %src: !pto.ptr<f32, ub>, %off: index) -> !pto.vmi.vreg<64xf32> {
    %c1 = arith.constant 1 : index
    %slot = pto.vmi.vload %src[%off], %c1 {group = 1}
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<1xf32>
    %out = pto.vmi.vbrc %slot {group = 1}
        : !pto.vmi.vreg<1xf32> -> !pto.vmi.vreg<64xf32>
    return %out : !pto.vmi.vreg<64xf32>
  }

  func.func @vmi_layout_assignment_group_slot_broadcast_load_brc_b32_two_chunks(
      %src: !pto.ptr<f32, ub>, %off: index) -> !pto.vmi.vreg<128xf32> {
    %c1 = arith.constant 1 : index
    %slot = pto.vmi.vload %src[%off], %c1 {group = 1}
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<1xf32>
    %out = pto.vmi.vbrc %slot {group = 1}
        : !pto.vmi.vreg<1xf32> -> !pto.vmi.vreg<128xf32>
    return %out : !pto.vmi.vreg<128xf32>
  }

  func.func @vmi_layout_assignment_group_slot_broadcast_load_brc_b32_stride(
      %src: !pto.ptr<f32, ub>, %off: index, %stride: index)
      -> !pto.vmi.vreg<128xf32> {
    %slot = pto.vmi.vload %src[%off], %stride {group = 2}
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<2xf32>
    %out = pto.vmi.vbrc %slot {group = 2}
        : !pto.vmi.vreg<2xf32> -> !pto.vmi.vreg<128xf32>
    return %out : !pto.vmi.vreg<128xf32>
  }
}

// CHECK-LABEL: func.func @vmi_layout_assignment_group_slot_broadcast_load_brc_b32
// CHECK-SAME: (%[[SRC:.*]]: !pto.ptr<f32, ub>, %[[OFF:.*]]: index)
// CHECK: %[[BRC:.*]] = pto.vlds %[[SRC]][%[[OFF]]] {dist = "BRC_B32"} : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
// CHECK: return %[[BRC]] : !pto.vreg<64xf32>

// CHECK-LABEL: func.func @vmi_layout_assignment_group_slot_broadcast_load_brc_b32_two_chunks
// CHECK-SAME: (%[[SRC2:.*]]: !pto.ptr<f32, ub>, %[[OFF2:.*]]: index)
// CHECK: %[[BRC0:.*]] = pto.vlds %[[SRC2]][%[[OFF2]]] {dist = "BRC_B32"} : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
// CHECK: %[[BRC1:.*]] = pto.vlds %[[SRC2]][%[[OFF2]]] {dist = "BRC_B32"} : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
// CHECK: return %[[BRC0]], %[[BRC1]] : !pto.vreg<64xf32>, !pto.vreg<64xf32>

// CHECK-LABEL: func.func @vmi_layout_assignment_group_slot_broadcast_load_brc_b32_stride
// CHECK-SAME: (%[[SRC3:.*]]: !pto.ptr<f32, ub>, %[[OFF3:.*]]: index, %[[STRIDE:.*]]: index)
// CHECK: %[[BRC2:.*]] = pto.vlds %[[SRC3]][%[[OFF3]]] {dist = "BRC_B32"} : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
// CHECK: %[[C1:.*]] = arith.constant 1 : index
// CHECK: %[[GROUP_DELTA:.*]] = arith.muli %[[STRIDE]], %[[C1]] : index
// CHECK: %[[GROUP1:.*]] = arith.addi %[[OFF3]], %[[GROUP_DELTA]] : index
// CHECK: %[[BRC3:.*]] = pto.vlds %[[SRC3]][%[[GROUP1]]] {dist = "BRC_B32"} : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
// CHECK: return %[[BRC2]], %[[BRC3]] : !pto.vreg<64xf32>, !pto.vreg<64xf32>
