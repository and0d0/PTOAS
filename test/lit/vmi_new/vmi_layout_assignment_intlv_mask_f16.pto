// RUN: pto-test-opt %s -vmi-mask-granularity-assignment -vmi-layout-assignment | FileCheck %s --check-prefix=ASSIGN
// RUN: pto-test-opt %s -vmi-mask-granularity-assignment -vmi-layout-assignment -vmi-to-vpto | FileCheck %s --check-prefix=LOWER

module {
  func.func @vmi_layout_assignment_intlv_mask_f16(
      %a: !pto.vmi.vreg<64xf16>,
      %b: !pto.vmi.vreg<64xf16>) {
    %c64 = arith.constant 64 : index
    %mask = pto.vmi.create_mask %c64 : index -> !pto.vmi.mask<64xpred>
    %even, %odd = pto.vmi.vdintlv %a, %b, %mask
        : !pto.vmi.vreg<64xf16>, !pto.vmi.vreg<64xf16>, !pto.vmi.mask<64xpred>
        -> !pto.vmi.vreg<64xf16>, !pto.vmi.vreg<64xf16>
    %lo, %hi = pto.vmi.vintlv %even, %odd, %mask
        : !pto.vmi.vreg<64xf16>, !pto.vmi.vreg<64xf16>, !pto.vmi.mask<64xpred>
        -> !pto.vmi.vreg<64xf16>, !pto.vmi.vreg<64xf16>
    return
  }
}

// ASSIGN-LABEL: func.func @vmi_layout_assignment_intlv_mask_f16(
// ASSIGN-SAME: %[[A:.*]]: !pto.vmi.vreg<64xf16, #pto.vmi.layout<contiguous>>, %[[B:.*]]: !pto.vmi.vreg<64xf16, #pto.vmi.layout<contiguous>>
// ASSIGN: %[[MASK:.*]] = pto.vmi.create_mask
// ASSIGN-SAME: -> !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
// ASSIGN: %[[M16_0:.*]] = pto.vmi.create_mask
// ASSIGN-SAME: -> !pto.vmi.mask<64xb16, #pto.vmi.layout<contiguous>>
// ASSIGN: %[[EVEN:.*]], %[[ODD:.*]] = pto.vmi.vdintlv %[[A]], %[[B]], %[[M16_0]]
// ASSIGN-SAME: !pto.vmi.mask<64xb16, #pto.vmi.layout<contiguous>>
// ASSIGN: %[[M16_1:.*]] = pto.vmi.create_mask
// ASSIGN-SAME: -> !pto.vmi.mask<64xb16, #pto.vmi.layout<contiguous>>
// ASSIGN: %[[LO:.*]], %[[HI:.*]] = pto.vmi.vintlv %[[EVEN]], %[[ODD]], %[[M16_1]]
// ASSIGN-SAME: !pto.vmi.mask<64xb16, #pto.vmi.layout<contiguous>>

// LOWER-LABEL: func.func @vmi_layout_assignment_intlv_mask_f16(
// LOWER: pto.pge_b32 "PAT_ALL"
// LOWER: pto.pge_b16 "PAT_VL64"
// LOWER: pto.vdintlv
// LOWER: pto.pge_b16 "PAT_VL64"
// LOWER: pto.vintlv
// LOWER-NOT: pto.vmi.
// LOWER-NOT: !pto.vmi.
// LOWER-NOT: unrealized_conversion_cast
