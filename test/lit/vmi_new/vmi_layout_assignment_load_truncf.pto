// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment | FileCheck %s --check-prefix=ASSIGN
// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment -vmi-to-vpto | FileCheck %s --check-prefix=LOWER

module {
  func.func @vmi_layout_assignment_load_truncf(
      %src: !pto.ptr<f32, ub>,
      %offset: index) -> !pto.vmi.vreg<128xf16> {
    %wide = pto.vmi.vload %src[%offset]
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<128xf32>
    %narrow = pto.vmi.vcvt %wide {saturate = "SAT"}
        : !pto.vmi.vreg<128xf32> -> !pto.vmi.vreg<128xf16>
    return %narrow : !pto.vmi.vreg<128xf16>
  }

  func.func @vmi_layout_assignment_load_truncf_multi_use(
      %src: !pto.ptr<f32, ub>,
      %dst: !pto.ptr<f32, ub>,
      %offset: index) -> !pto.vmi.vreg<128xf16> {
    %wide = pto.vmi.vload %src[%offset]
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<128xf32>
    pto.vmi.vstore %wide, %dst[%offset]
        : !pto.vmi.vreg<128xf32>, !pto.ptr<f32, ub>
    %narrow = pto.vmi.vcvt %wide {saturate = "SAT"}
        : !pto.vmi.vreg<128xf32> -> !pto.vmi.vreg<128xf16>
    return %narrow : !pto.vmi.vreg<128xf16>
  }

}

// ASSIGN-LABEL: func.func @vmi_layout_assignment_load_truncf(
// ASSIGN-SAME: -> !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: %[[WIDE:.*]] = pto.vmi.load
// ASSIGN-SAME: !pto.ptr<f32, ub> -> !pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>>
// ASSIGN-NOT: pto.vmi.ensure_layout
// ASSIGN: %[[NARROW:.*]] = pto.vmi.truncf %[[WIDE]]
// ASSIGN-SAME: !pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>> -> !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: return %[[NARROW]] : !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous, lane_stride = 2>>

// LOWER-LABEL: func.func @vmi_layout_assignment_load_truncf(
// LOWER: %[[PART0:.*]] = pto.vlds
// LOWER: %[[PART1:.*]] = pto.vlds
// LOWER: %[[NARROW0:.*]] = pto.vcvt %[[PART0]], {{.*}} {part = "EVEN", rnd = "R", sat = "SAT"}
// LOWER: %[[NARROW1:.*]] = pto.vcvt %[[PART1]], {{.*}} {part = "EVEN", rnd = "R", sat = "SAT"}
// LOWER-NOT: part = "ODD"
// LOWER-NOT: pto.vor
// LOWER: return %[[NARROW0]], %[[NARROW1]] : !pto.vreg<128xf16>, !pto.vreg<128xf16>
// LOWER-NOT: pto.vmi.
// LOWER-NOT: !pto.vmi.

// ASSIGN-LABEL: func.func @vmi_layout_assignment_load_truncf_multi_use(
// ASSIGN-SAME: -> !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: %[[WIDE:.*]] = pto.vmi.load
// ASSIGN-SAME: !pto.ptr<f32, ub> -> !pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>>
// ASSIGN-NOT: pto.vmi.ensure_layout %[[WIDE]]
// ASSIGN: pto.vmi.store %[[WIDE]]
// ASSIGN-SAME: !pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>>
// ASSIGN: %[[NARROW:.*]] = pto.vmi.truncf %[[WIDE]]
// ASSIGN-SAME: !pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>> -> !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: return %[[NARROW]] : !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous, lane_stride = 2>>

// LOWER-LABEL: func.func @vmi_layout_assignment_load_truncf_multi_use(
// LOWER: %[[PART0:.*]] = pto.vlds
// LOWER: %[[PART1:.*]] = pto.vlds
// LOWER: pto.vsts %[[PART0]]
// LOWER: pto.vsts %[[PART1]]
// LOWER: pto.vcvt {{.*}} {part = "EVEN", rnd = "R", sat = "SAT"}
// LOWER: pto.vcvt {{.*}} {part = "EVEN", rnd = "R", sat = "SAT"}
// LOWER-NOT: part = "ODD"
// LOWER-NOT: pto.vor
// LOWER: return {{.*}}, {{.*}} : !pto.vreg<128xf16>, !pto.vreg<128xf16>
// LOWER-NOT: pto.vmi.
// LOWER-NOT: !pto.vmi.
