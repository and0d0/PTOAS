// RUN: pto-test-opt %s -vmi-mask-granularity-assignment -vmi-layout-assignment | FileCheck %s

module {
  func.func @scf_while_independent_carry_sequences(
      %f16_value: !pto.vmi.vreg<128xf16>,
      %f32_value: !pto.vmi.vreg<128xf32>,
      %keep_going: i1)
      -> (!pto.vmi.vreg<128xf32>, !pto.vmi.vreg<128xf16>) {
    %result:2 = scf.while (%before_f16 = %f16_value,
                           %before_f32 = %f32_value)
        : (!pto.vmi.vreg<128xf16>, !pto.vmi.vreg<128xf32>)
        -> (!pto.vmi.vreg<128xf32>, !pto.vmi.vreg<128xf16>) {
      scf.condition(%keep_going) %before_f32, %before_f16
          : !pto.vmi.vreg<128xf32>, !pto.vmi.vreg<128xf16>
    } do {
    ^bb0(%after_f32: !pto.vmi.vreg<128xf32>,
         %after_f16: !pto.vmi.vreg<128xf16>):
      scf.yield %after_f16, %after_f32
          : !pto.vmi.vreg<128xf16>, !pto.vmi.vreg<128xf32>
    }
    return %result#0, %result#1
        : !pto.vmi.vreg<128xf32>, !pto.vmi.vreg<128xf16>
  }
}

// CHECK-LABEL: func.func @scf_while_independent_carry_sequences(
// CHECK: scf.while
// CHECK-SAME: : (!pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous>>, !pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>>)
// CHECK-SAME: -> (!pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>>, !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous>>)
// CHECK: scf.condition
// CHECK-SAME: !pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>>, !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous>>
// CHECK: ^bb0({{.*}}!pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>>{{.*}}!pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous>>)
