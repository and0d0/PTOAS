// RUN: not pto-test-opt %s -split-input-file 2>&1 | FileCheck %s

module {
  func.func @vmi_vand_mask_lane_mismatch(
      %lhs: !pto.vmi.mask<128xpred>,
      %rhs: !pto.vmi.mask<64xpred>) {
    %and = pto.vmi.vand %lhs, %rhs
        : !pto.vmi.mask<128xpred>, !pto.vmi.mask<64xpred>
        -> !pto.vmi.mask<128xpred>
    return
  }
}

// CHECK: 'pto.vmi.vand' op requires all VMI mask values to have the same logical lane count

// -----

module {
  func.func @vmi_vor_mask_granularity_mismatch(
      %lhs: !pto.vmi.mask<128xb16, #pto.vmi.layout<contiguous>>,
      %rhs: !pto.vmi.mask<128xb32, #pto.vmi.layout<contiguous>>) {
    %or = pto.vmi.vor %lhs, %rhs
        : !pto.vmi.mask<128xb16, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<128xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.mask<128xb16, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: 'pto.vmi.vor' op requires all VMI mask values to have the same granularity

// -----

module {
  func.func @vmi_vxor_mask_lane_mismatch(
      %lhs: !pto.vmi.mask<128xpred>,
      %rhs: !pto.vmi.mask<64xpred>) {
    %xor = pto.vmi.vxor %lhs, %rhs
        : !pto.vmi.mask<128xpred>, !pto.vmi.mask<64xpred>
        -> !pto.vmi.mask<128xpred>
    return
  }
}

// CHECK: 'pto.vmi.vxor' op requires all VMI mask values to have the same logical lane count

// -----

module {
  func.func @vmi_vnot_mask_granularity_mismatch(
      %src: !pto.vmi.mask<128xb16, #pto.vmi.layout<contiguous>>) {
    %not = pto.vmi.vnot %src
        : !pto.vmi.mask<128xb16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.mask<128xb32, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: 'pto.vmi.vnot' op requires all VMI mask values to have the same granularity

// -----

module {
  func.func @vmi_vand_mask_predication_rejected(
      %lhs: !pto.vmi.mask<128xpred>,
      %rhs: !pto.vmi.mask<128xpred>,
      %pred: !pto.vmi.mask<128xpred>) {
    %and = pto.vmi.vand %lhs, %rhs, %pred
        : !pto.vmi.mask<128xpred>, !pto.vmi.mask<128xpred>, !pto.vmi.mask<128xpred>
        -> !pto.vmi.mask<128xpred>
    return
  }
}

// CHECK: 'pto.vmi.vand' op mask logic op does not support predication mask

// -----

module {
  func.func @vmi_vand_mask_pmode_rejected(
      %lhs: !pto.vmi.mask<128xpred>,
      %rhs: !pto.vmi.mask<128xpred>) {
    %and = pto.vmi.vand %lhs, %rhs {pmode = "merge"}
        : !pto.vmi.mask<128xpred>, !pto.vmi.mask<128xpred>
        -> !pto.vmi.mask<128xpred>
    return
  }
}

// CHECK: 'pto.vmi.vand' op mask logic op does not support pmode

// -----

module {
  func.func @vmi_vnot_mask_predication_rejected(
      %src: !pto.vmi.mask<128xpred>,
      %pred: !pto.vmi.mask<128xpred>) {
    %not = pto.vmi.vnot %src, %pred
        : !pto.vmi.mask<128xpred>, !pto.vmi.mask<128xpred>
        -> !pto.vmi.mask<128xpred>
    return
  }
}

// CHECK: 'pto.vmi.vnot' op mask logic op does not support predication mask
