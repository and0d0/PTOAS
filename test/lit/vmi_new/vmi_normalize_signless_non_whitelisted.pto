// RUN: pto-test-opt %s -pto-vmi-normalize-signless-int-to-unsigned | FileCheck %s

module {
  func.func @non_whitelisted_vaddi_signless(
      %lhs: !pto.vmi.vreg<128xi32>,
      %rhs: !pto.vmi.vreg<128xi32>) -> !pto.vmi.vreg<128xi32> {
    %out = pto.vmi.vadd %lhs, %rhs
        : !pto.vmi.vreg<128xi32>, !pto.vmi.vreg<128xi32>
        -> !pto.vmi.vreg<128xi32>
    return %out : !pto.vmi.vreg<128xi32>
  }
}

// CHECK-LABEL: func.func @non_whitelisted_vaddi_signless(
// CHECK: pto.vmi.vadd %{{.*}}, %{{.*}} : !pto.vmi.vreg<128xi32>, !pto.vmi.vreg<128xi32> -> !pto.vmi.vreg<128xi32>
// CHECK-NOT: pto.vmi.bitcast
