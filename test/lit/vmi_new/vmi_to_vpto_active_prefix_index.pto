// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_to_vpto_active_prefix_index(
      %mask: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<64xi32> {
    %idx = pto.vmi.active_prefix_index %mask
        : !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>
    %part = "pto.vmi.unpack"(%idx)
        : (!pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<64xi32>
    return %part : !pto.vreg<64xi32>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_active_prefix_index(
// CHECK-DAG: %[[ZERO:.*]] = arith.constant 0 : i32
// CHECK-DAG: %[[M:.*]] = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>
// CHECK: %[[CARRIER:.*]] = pto.vdup %[[ZERO]], %[[M]] : i32, !pto.mask<b32> -> !pto.vreg<64xi32>
// CHECK: %[[IDX:.*]] = pto.vusqz %[[CARRIER]], %arg0 : !pto.vreg<64xi32>, !pto.mask<b32> -> !pto.vreg<64xi32>
// CHECK: return %[[IDX]]
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
