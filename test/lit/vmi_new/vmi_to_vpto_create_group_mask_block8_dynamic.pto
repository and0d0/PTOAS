// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_to_vpto_create_group_mask_block8_dynamic(%active: index)
      -> !pto.vmi.mask<128xb32, #pto.vmi.layout<block_deinterleaved = 2>> {
    %mask = pto.vmi.create_group_mask %active
        {num_groups = 8, group_size = 16}
        : index -> !pto.vmi.mask<128xb32, #pto.vmi.layout<block_deinterleaved = 2>>
    return %mask
        : !pto.vmi.mask<128xb32, #pto.vmi.layout<block_deinterleaved = 2>>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_create_group_mask_block8_dynamic(
// CHECK-SAME: -> (!pto.mask<b32>, !pto.mask<b32>)
// CHECK: arith.index_cast
// CHECK: arith.maxsi
// CHECK: arith.minui
// CHECK: pto.vci
// CHECK: pto.vshrs
// CHECK: pto.vshls
// CHECK: pto.vsub
// CHECK: pto.vmuls
// CHECK: pto.vcmps
// CHECK: pto.vci
// CHECK: pto.vshrs
// CHECK: pto.vshls
// CHECK: pto.vsub
// CHECK: pto.vmuls
// CHECK: pto.vadds
// CHECK: pto.vcmps
// CHECK: return
// CHECK-NOT: pto.pdintlv_b32
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
