// RUN: not pto-test-opt %s -split-input-file -vmi-lower-unified-to-legacy -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_addf_f64_unsupported(
      %a: !pto.vmi.vreg<32xf64, #pto.vmi.layout<contiguous>>,
      %b: !pto.vmi.vreg<32xf64, #pto.vmi.layout<contiguous>>) {
    %sum = pto.vmi.vadd %a, %b
        : !pto.vmi.vreg<32xf64, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<32xf64, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<32xf64, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: expected an 8-bit, 16-bit, or 32-bit logical element type

// -----

module {
  func.func @vmi_addi_index_unsupported(
      %a: !pto.vmi.vreg<64xindex, #pto.vmi.layout<contiguous>>,
      %b: !pto.vmi.vreg<64xindex, #pto.vmi.layout<contiguous>>) {
    %sum = pto.vmi.vadd %a, %b
        : !pto.vmi.vreg<64xindex, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<64xindex, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xindex, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: expected an 8-bit, 16-bit, or 32-bit logical element type
