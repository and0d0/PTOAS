// RUN: not pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_to_vpto_fma_f8_invalid(
      %lhs: !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>,
      %rhs: !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>,
      %acc: !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>) {
    %out = pto.vmi.vmula %acc, %lhs, %rhs
        : !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>
    return
  }
}

// vmula(mask optional) with f8 parses and lowers to legacy fma;
// fma's verifier rejects the f8 element type.
// CHECK: 'pto.vmi.fma' op requires f16, bf16, or f32 VMI element type
