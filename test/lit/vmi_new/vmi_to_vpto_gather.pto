// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_to_vpto_gather(
      %src: !pto.ptr<f32, ub>,
      %indices: !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<64xf32> {
    %out = pto.vmi.vgather %src, %indices, %mask
        : !pto.ptr<f32, ub>,
          !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
    %part = "pto.vmi.unpack"(%out)
        : (!pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<64xf32>
    return %part : !pto.vreg<64xf32>
  }
}

// vgather (pmode="zero") lowers to a legacy gather with a synthesised zero
// passthru, then to pto.vgather2_bc + pto.vsel; inactive lanes select the zero
// constant (wildcarded below) instead of an explicit passthru operand.
// CHECK-LABEL: func.func @vmi_to_vpto_gather(
// CHECK: %[[GATHER:.*]] = pto.vgather2_bc %arg0, %arg1, %arg2 : !pto.ptr<f32, ub>, !pto.vreg<64xi32>, !pto.mask<b32> -> !pto.vreg<64xf32>
// CHECK: %[[OUT:.*]] = pto.vsel %[[GATHER]], %{{.*}}, %arg2 : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xf32>
// CHECK: return %[[OUT]]
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
