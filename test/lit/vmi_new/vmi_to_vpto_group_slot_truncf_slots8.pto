// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_to_vpto_group_slot_truncf_slots8(
      %src: !pto.ptr<f32, ub>, %off: index) -> !pto.vreg<128xf16> {
    %c1 = arith.constant 1 : index
    %source = pto.vmi.group_slot_load %src[%off], %c1 {num_groups = 8}
        : !pto.ptr<f32, ub>
        -> !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 8>>
    %out = pto.vmi.vcvt %source
        : !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 8>>
        -> !pto.vmi.vreg<8xf16, #pto.vmi.layout<num_groups = 8, slots = 8, lane_stride = 2>>
    %part = "pto.vmi.unpack"(%out)
        : (!pto.vmi.vreg<8xf16, #pto.vmi.layout<num_groups = 8, slots = 8, lane_stride = 2>>)
        -> !pto.vreg<128xf16>
    return %part : !pto.vreg<128xf16>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_group_slot_truncf_slots8(
// CHECK: %[[SRC:.*]] = pto.vsldb
// CHECK: %[[MASK:.*]] = pto.pge_b32 "PAT_VL8" : !pto.mask<b32>
// CHECK: %[[OUT:.*]] = pto.vcvt %[[SRC]], %[[MASK]] {part = "EVEN", rnd = "R", sat = "SAT"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<128xf16>
// CHECK: return %[[OUT]]
// CHECK-NOT: pto.vmi.
