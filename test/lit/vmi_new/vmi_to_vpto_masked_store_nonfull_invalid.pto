// RUN: not pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_to_vpto_masked_store_nonfull_invalid(
      %value: !pto.vmi.vreg<129xf32, #pto.vmi.layout<deinterleaved = 2>>,
      %mask: !pto.vmi.mask<129xb32, #pto.vmi.layout<deinterleaved = 2>>,
      %dst: !pto.ptr<f32, ub>,
      %offset: index) {
    pto.vmi.vstore %value, %dst[%offset], %mask
        : !pto.vmi.vreg<129xf32, #pto.vmi.layout<deinterleaved = 2>>,
          !pto.ptr<f32, ub>,
          !pto.vmi.mask<129xb32, #pto.vmi.layout<deinterleaved = 2>>
    return
  }
}

// CHECK: VMI{{-}}UNSUPPORTED{{:}} pto.vmi.masked_store requires either full physical chunks or contiguous tail-store value/mask layout
// CHECK-SAME: requires every deinterleaved part to have the same physical chunk count
