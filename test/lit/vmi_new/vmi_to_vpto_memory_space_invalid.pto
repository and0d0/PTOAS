// RUN: not pto-test-opt %s -split-input-file -vmi-lower-unified-to-legacy -vmi-to-vpto 2>&1 | FileCheck %s

// Module 1: vload GM-backed → lowered to load → verifier rejects non-UB memory
module {
  func.func @vmi_load_gm_unsupported(%src: !pto.ptr<f32, gm>, %offset: index) {
    %value = pto.vmi.vload %src[%offset]
        : !pto.ptr<f32, gm> -> !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: 'pto.vmi.load' op requires memory source to be UB-backed

// -----

// Module 2: masked_load GM-backed → lowered → verifier rejects non-UB memory
module {
  func.func @vmi_masked_load_gm_unsupported(
      %src: !pto.ptr<f32, gm>,
      %mask: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>,
      %passthru: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
      %offset: index) {
    %value = pto.vmi.masked_load %src[%offset], %mask, %passthru
        : !pto.ptr<f32, gm>, !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
          -> !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: 'pto.vmi.masked_load' op requires memory source to be UB-backed

// -----

// Module 3: expand_load GM-backed → legacy op, VPTO walk rejects
module {
  func.func @vmi_expand_load_gm_unsupported(
      %src: !pto.ptr<f32, gm>,
      %mask: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>,
      %passthru: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
      %offset: index) {
    %value = pto.vmi.expand_load %src[%offset], %mask, %passthru
        : !pto.ptr<f32, gm>, !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
          -> !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: 'pto.vmi.expand_load' op requires memory source to be UB-backed

// -----

// Module 4: vstore GM-backed → lowered to store → verifier rejects non-UB memory
module {
  func.func @vmi_store_gm_unsupported(
      %value: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
      %dst: !pto.ptr<f32, gm>,
      %offset: index) {
    pto.vmi.vstore %value, %dst[%offset]
        : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>, !pto.ptr<f32, gm>
    return
  }
}

// CHECK: 'pto.vmi.store' op requires memory destination to be UB-backed

// -----

// Module 5: masked_store GM-backed → lowered → verifier rejects non-UB memory
module {
  func.func @vmi_masked_store_gm_unsupported(
      %value: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>,
      %dst: !pto.ptr<f32, gm>,
      %offset: index) {
    pto.vmi.vstore %value, %dst[%offset], %mask
        : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
          !pto.ptr<f32, gm>, !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: 'pto.vmi.masked_store' op requires memory destination to be UB-backed
