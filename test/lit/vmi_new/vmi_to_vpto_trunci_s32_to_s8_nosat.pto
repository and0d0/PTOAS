// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto | FileCheck %s

// s32 -> s8 IntNarrow with saturate = "NOSAT".  The s32->s8 path is
// materialised as vbitcast(si32->ui32) + vcvt(ui32->ui8 NOSAT) + vbitcast(ui8->si8).
// 4 x pto.vcvt (P0..P3) with sat = "NOSAT" on ui32->ui8, then 3 x pto.vor
// merging, and a trailing vbitcast back to si8.

module {
  func.func @vmi_to_vpto_trunci_s32_to_s8_nosat(
      %wide: !pto.vmi.vreg<256xsi32, #pto.vmi.layout<deinterleaved = 4>>)
      -> !pto.vreg<256xsi8> {
    %narrow = pto.vmi.vcvt %wide {saturate = "NOSAT"}
        : !pto.vmi.vreg<256xsi32, #pto.vmi.layout<deinterleaved = 4>>
        -> !pto.vmi.vreg<256xsi8, #pto.vmi.layout<contiguous>>
    %p = "pto.vmi.unpack"(%narrow)
        : (!pto.vmi.vreg<256xsi8, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<256xsi8>
    return %p : !pto.vreg<256xsi8>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_trunci_s32_to_s8_nosat(
// CHECK: pto.vbitcast {{.*}} : !pto.vreg<64xsi32> -> !pto.vreg<64xui32>
// CHECK: pto.vbitcast {{.*}} : !pto.vreg<64xsi32> -> !pto.vreg<64xui32>
// CHECK: pto.vbitcast {{.*}} : !pto.vreg<64xsi32> -> !pto.vreg<64xui32>
// CHECK: pto.vbitcast {{.*}} : !pto.vreg<64xsi32> -> !pto.vreg<64xui32>
// CHECK: pto.vcvt
// CHECK-SAME: part = "P0"
// CHECK-SAME: sat = "NOSAT"
// CHECK: pto.vcvt
// CHECK-SAME: part = "P1"
// CHECK-SAME: sat = "NOSAT"
// CHECK: pto.vcvt
// CHECK-SAME: part = "P2"
// CHECK-SAME: sat = "NOSAT"
// CHECK: pto.vcvt
// CHECK-SAME: part = "P3"
// CHECK-SAME: sat = "NOSAT"
// CHECK: pto.vor
// CHECK: pto.vor
// CHECK: pto.vor
// CHECK: pto.vbitcast {{.*}} : !pto.vreg<256xui8> -> !pto.vreg<256xsi8>
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
