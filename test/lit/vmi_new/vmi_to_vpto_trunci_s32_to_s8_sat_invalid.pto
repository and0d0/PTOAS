// RUN: not pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto 2>&1 | FileCheck %s

// si32 -> si8 IntNarrow has no native hardware form; lowering aliases through
// ui32 -> ui8 which is bit-pattern equivalent ONLY under NOSAT.  saturate="SAT"
// must be rejected by the VMI verifier (ui32->ui8 SAT would clamp to [0,255]
// instead of the expected [-128,127]).

module {
  func.func @vmi_to_vpto_trunci_s32_to_s8_sat_invalid(
      %wide: !pto.vmi.vreg<256xsi32, #pto.vmi.layout<deinterleaved = 4>>)
      -> !pto.vreg<256xsi8> {
    %narrow = pto.vmi.vcvt %wide {saturate = "SAT"}
        : !pto.vmi.vreg<256xsi32, #pto.vmi.layout<deinterleaved = 4>>
        -> !pto.vmi.vreg<256xsi8, #pto.vmi.layout<contiguous>>
    %p = "pto.vmi.unpack"(%narrow)
        : (!pto.vmi.vreg<256xsi8, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<256xsi8>
    return %p : !pto.vreg<256xsi8>
  }
}

// CHECK: 'pto.vmi.vcvt' op si32 -> si8 int-narrow does not support saturate="SAT"
