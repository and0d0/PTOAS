// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_to_vpto_type_only(
      %a: !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
      %m: !pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>) {
    return
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_type_only(
// CHECK-SAME: !pto.vreg<64xf32>
// CHECK-SAME: !pto.vreg<64xf32>
// CHECK-SAME: !pto.mask<b32>
// CHECK-SAME: !pto.mask<b32>
// CHECK: return
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
// CHECK-NOT: pto.vmi.
