// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

module {
  func.func @vmi_truncf_rounding_token_invalid(
      %source: !pto.vmi.vreg<256xf32>) {
    %result = pto.vmi.vcvt %source {rounding = "R"}
        : !pto.vmi.vreg<256xf32> -> !pto.vmi.vreg<256x!pto.hif8>
    return
  }
}

// vcvt accepts the extra "Z" (toward-zero) token, so the message differs from
// the legacy truncf wording; "R" is still rejected.
// CHECK: op rounding must be 'A' (away-from-zero), 'H' (half-up), or 'Z' (toward-zero)
