// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto --mlir-print-ir-before=vpto-expand-wrapper-ops %s -o /dev/null 2>&1 | FileCheck %s --check-prefix=SEMANTIC
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto --mlir-print-ir-after=vpto-expand-wrapper-ops %s -o /dev/null 2>&1 | FileCheck %s --check-prefix=EXPAND

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<cube>} {
  func.func @mad_fp8_semantic_to_raw(
      %lhs_e4: !pto.ptr<f8E4M3FN, l0a>,
      %rhs_e4: !pto.ptr<f8E4M3FN, l0b>,
      %lhs_e5: !pto.ptr<f8E5M2, l0a>,
      %rhs_e5: !pto.ptr<f8E5M2, l0b>,
      %dst: !pto.ptr<f32, l0c>,
      %bias: !pto.ptr<f32, bt>) attributes {pto.kernel} {
    %c16 = arith.constant 16 : i64
    pto.mad %lhs_e4, %rhs_e4, %dst, %c16, %c16, %c16
      : !pto.ptr<f8E4M3FN, l0a>, !pto.ptr<f8E4M3FN, l0b>, !pto.ptr<f32, l0c>, i64, i64, i64
    pto.mad_acc %lhs_e4, %rhs_e5, %dst, %c16, %c16, %c16
      : !pto.ptr<f8E4M3FN, l0a>, !pto.ptr<f8E5M2, l0b>, !pto.ptr<f32, l0c>, i64, i64, i64
    pto.mad_bias %lhs_e5, %rhs_e4, %dst, %bias, %c16, %c16, %c16
      : !pto.ptr<f8E5M2, l0a>, !pto.ptr<f8E4M3FN, l0b>, !pto.ptr<f32, l0c>, !pto.ptr<f32, bt>, i64, i64, i64
    pto.mad %lhs_e5, %rhs_e5, %dst, %c16, %c16, %c16
      : !pto.ptr<f8E5M2, l0a>, !pto.ptr<f8E5M2, l0b>, !pto.ptr<f32, l0c>, i64, i64, i64
    return
  }
}

// SEMANTIC-LABEL: func.func @mad_fp8_semantic_to_raw(
// SEMANTIC: pto.mad {{.*}}!pto.ptr<f8E4M3FN, l0a>, !pto.ptr<f8E4M3FN, l0b>, !pto.ptr<f32, l0c>
// SEMANTIC: pto.mad_acc {{.*}}!pto.ptr<f8E4M3FN, l0a>, !pto.ptr<f8E5M2, l0b>, !pto.ptr<f32, l0c>
// SEMANTIC: pto.mad_bias {{.*}}!pto.ptr<f8E5M2, l0a>, !pto.ptr<f8E4M3FN, l0b>, !pto.ptr<f32, l0c>
// SEMANTIC: pto.mad {{.*}}!pto.ptr<f8E5M2, l0a>, !pto.ptr<f8E5M2, l0b>, !pto.ptr<f32, l0c>

// EXPAND-LABEL: func.func @mad_fp8_semantic_to_raw(
// EXPAND: pto.mad_raw {{.*}}!pto.ptr<f8E4M3FN, l0a>, !pto.ptr<f8E4M3FN, l0b>, !pto.ptr<f32, l0c>
// EXPAND: pto.mad_raw {{.*}}!pto.ptr<f8E4M3FN, l0a>, !pto.ptr<f8E5M2, l0b>, !pto.ptr<f32, l0c>
// EXPAND: pto.mad_bias_raw {{.*}}!pto.ptr<f8E5M2, l0a>, !pto.ptr<f8E4M3FN, l0b>, !pto.ptr<f32, l0c>, !pto.ptr<f32, bt>
// EXPAND: pto.mad_raw {{.*}}!pto.ptr<f8E5M2, l0a>, !pto.ptr<f8E5M2, l0b>, !pto.ptr<f32, l0c>
// EXPAND-NOT: pto.mad_mx_raw
