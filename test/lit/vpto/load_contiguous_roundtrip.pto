// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto %s -o - 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @load_contiguous_roundtrip_kernel(%src: !pto.ptr<f32, ub>, %dst: !pto.ptr<f32, ub>) attributes {pto.aicore} {
    %dim_z = arith.constant 1 : i32
    %dim_y = arith.constant 1 : i32
    %dim_x = arith.constant 128 : i32
    pto.store_vfsimt_info %dim_z, %dim_y, %dim_x : i32, i32, i32
    func.call @load_contiguous_roundtrip_body(%src, %dst) : (!pto.ptr<f32, ub>, !pto.ptr<f32, ub>) -> ()
    return
  }

  func.func @load_contiguous_roundtrip_body(%src: !pto.ptr<f32, ub>, %dst: !pto.ptr<f32, ub>) attributes {pto.simt_entry} {
    %tx = pto.get_tid_x : i32
    %c4_i32 = arith.constant 4 : i32
    %off_i32 = arith.muli %tx, %c4_i32 : i32
    %off = arith.index_castui %off_i32 : i32 to index
    %v = pto.load_contiguous %src[%off] : !pto.ptr<f32, ub> -> vector<4xf32>
    pto.store_contiguous %v, %dst[%off] : vector<4xf32>, !pto.ptr<f32, ub>
    return
  }
}

// CHECK-LABEL: func.func @load_contiguous_roundtrip_body
// CHECK: pto.load_contiguous {{.*}} : !pto.ptr<f32, ub> -> vector<4xf32>
// CHECK: pto.store_contiguous {{.*}} : vector<4xf32>, !pto.ptr<f32, ub>
