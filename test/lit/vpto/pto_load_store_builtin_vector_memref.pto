// RUN: ( mkdir -p %T && ptoas --pto-arch=a5 --pto-backend=vpto %s -o %t --mlir-print-ir-after=convert-func-to-llvm 2>&1 || true ) | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @pto_load_store_builtin_vector_memref(
      %src: memref<16xf32, #pto.address_space<vec>>,
      %dst: memref<16xf32, #pto.address_space<vec>>) attributes {pto.simt_entry} {
    %c4 = arith.constant 4 : index
    %value = pto.load %src[%c4] : memref<16xf32, #pto.address_space<vec>> -> vector<4xf32>
    pto.store %value, %dst[%c4] : memref<16xf32, #pto.address_space<vec>>, vector<4xf32>
    return
  }
}

// CHECK-LABEL: llvm.func @pto_load_store_builtin_vector_memref
// CHECK: llvm.getelementptr {{.*}} : (!llvm.ptr<6>, i64) -> !llvm.ptr<6>, f32
// CHECK: llvm.load {{.*}} : !llvm.ptr<6> -> vector<4xf32>
// CHECK: llvm.getelementptr {{.*}} : (!llvm.ptr<6>, i64) -> !llvm.ptr<6>, f32
// CHECK: llvm.store {{.*}} : vector<4xf32>, !llvm.ptr<6>
