// RUN: ( mkdir -p %T && ptoas --pto-arch=a5 --pto-backend=vpto %s -o %t --mlir-print-ir-after=convert-func-to-llvm 2>&1 || true ) | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @fp8x2_ldg_stg_kernel(
      %gm_e4: !pto.ptr<vector<2xf8E4M3FN>, gm>,
      %gm_e5: !pto.ptr<vector<2xf8E5M2>, gm>,
      %gm_h8: !pto.ptr<!pto.hif8x2, gm>) attributes {pto.aicore} {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index

    %e4 = pto.ldg %gm_e4[%c0] l1cache(cache) l2cache(nmfv) : !pto.ptr<vector<2xf8E4M3FN>, gm> -> vector<2xf8E4M3FN>
    %e5 = pto.ldg %gm_e5[%c0] l1cache(uncache) l2cache(nmfv) : !pto.ptr<vector<2xf8E5M2>, gm> -> vector<2xf8E5M2>
    %h8 = pto.ldg %gm_h8[%c0] l1cache(cache) l2cache(nmfv) : !pto.ptr<!pto.hif8x2, gm> -> !pto.hif8x2

    pto.stg %e4, %gm_e4[%c1] l1cache(cache) l2cache(nmfv) : !pto.ptr<vector<2xf8E4M3FN>, gm>, vector<2xf8E4M3FN>
    pto.stg %e5, %gm_e5[%c1] l1cache(uncache) l2cache(nmfv) : !pto.ptr<vector<2xf8E5M2>, gm>, vector<2xf8E5M2>
    pto.stg %h8, %gm_h8[%c1] l1cache(cache) l2cache(nmfv) : !pto.ptr<!pto.hif8x2, gm>, !pto.hif8x2
    return
  }
}

// CHECK-LABEL: llvm.func @fp8x2_ldg_stg_kernel_mix_aiv
// CHECK-DAG: llvm.call @llvm.hivm.ldg.cache.s16
// CHECK-DAG: llvm.call @llvm.hivm.ldg.uncache.s16
// CHECK-DAG: llvm.call @llvm.hivm.stg.cache.b16
// CHECK-DAG: llvm.call @llvm.hivm.stg.uncache.b16
