// RUN: not ptoas --pto-arch=a5 --pto-backend=vpto %s -o %t 2>&1 | FileCheck %s --implicit-check-not=error

// Test that pto.ldg/pto.stg correctly reject:
// 1. Non-GM address space (UB pointer)
// 2. Unsupported vector types (wrong element count, element type)

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @bad_addr_space(%ub_i32: !pto.ptr<i32, ub>) attributes {pto.aicore} {
    %c0 = arith.constant 0 : index
    %v = pto.ldg %ub_i32[%c0] l1cache(cache) l2cache(nmfv) : !pto.ptr<i32, ub> -> i32
    pto.store %v, %ub_i32[%c0] : !pto.ptr<i32, ub>, i32
    return
  }

  func.func @bad_v4f32(%gm: !pto.ptr<vector<4xf32>, gm>) attributes {pto.aicore} {
    %c0 = arith.constant 0 : index
    %v = pto.ldg %gm[%c0] l1cache(cache) l2cache(nmfv) : !pto.ptr<vector<4xf32>, gm> -> vector<4xf32>
    return
  }

  func.func @bad_v3f16(%gm: !pto.ptr<vector<3xf16>, gm>) attributes {pto.aicore} {
    %c0 = arith.constant 0 : index
    %v = pto.ldg %gm[%c0] l1cache(cache) l2cache(nmfv) : !pto.ptr<vector<3xf16>, gm> -> vector<3xf16>
    return
  }

  func.func @bad_v2i32(%gm: !pto.ptr<vector<2xi32>, gm>) attributes {pto.aicore} {
    %c0 = arith.constant 0 : index
    %v = pto.ldg %gm[%c0] l1cache(cache) l2cache(nmfv) : !pto.ptr<vector<2xi32>, gm> -> vector<2xi32>
    return
  }

  func.func @bad_stg_addr_space(%ub: !pto.ptr<i32, ub>) attributes {pto.aicore} {
    %c0 = arith.constant 0 : index
    %v = arith.constant 42 : i32
    pto.stg %v, %ub[%c0] l1cache(cache) l2cache(nmfv) : !pto.ptr<i32, ub>, i32
    return
  }
}

// CHECK: requires GM pointer
// CHECK: vector<2xf16>/vector<2xbf16>/vector<2xf32> value type
// CHECK: vector<2xf16>/vector<2xbf16>/vector<2xf32> value type
// CHECK: vector<2xf16>/vector<2xbf16>/vector<2xf32> value type
// CHECK: requires GM pointer
