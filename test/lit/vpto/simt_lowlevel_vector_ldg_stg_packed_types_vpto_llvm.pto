// RUN: ( mkdir -p %T && ptoas --pto-arch=a5 --pto-backend=vpto %s -o %t --mlir-print-ir-after=convert-func-to-llvm 2>&1 || true ) | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @packed_vector_ldst_kernel(
      %gm_f8e4: !pto.ptr<vector<2xf8E4M3FN>, gm>,
      %gm_f8e5: !pto.ptr<vector<2xf8E5M2>, gm>,
      %gm_hif8x2: !pto.ptr<!pto.hif8x2, gm>,
      %gm_i8: !pto.ptr<vector<2xi8>, gm>,
      %gm_i16: !pto.ptr<vector<2xi16>, gm>,
      %gm_i32: !pto.ptr<vector<2xi32>, gm>
  ) attributes {pto.aicore} {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index

    // 16-bit total: load via s16, store via b16
    %v_f8e4 = pto.ldg %gm_f8e4[%c0] : !pto.ptr<vector<2xf8E4M3FN>, gm> -> vector<2xf8E4M3FN>
    pto.stg %v_f8e4, %gm_f8e4[%c1] : !pto.ptr<vector<2xf8E4M3FN>, gm>, vector<2xf8E4M3FN>

    %v_f8e5 = pto.ldg %gm_f8e5[%c0] : !pto.ptr<vector<2xf8E5M2>, gm> -> vector<2xf8E5M2>
    pto.stg %v_f8e5, %gm_f8e5[%c1] : !pto.ptr<vector<2xf8E5M2>, gm>, vector<2xf8E5M2>

    // !pto.hif8x2 is a 2-byte packed hif8 value type.
    %v_hif8x2 = pto.ldg %gm_hif8x2[%c0] : !pto.ptr<!pto.hif8x2, gm> -> !pto.hif8x2
    pto.stg %v_hif8x2, %gm_hif8x2[%c1] : !pto.ptr<!pto.hif8x2, gm>, !pto.hif8x2

    %v_i8 = pto.ldg %gm_i8[%c0] : !pto.ptr<vector<2xi8>, gm> -> vector<2xi8>
    pto.stg %v_i8, %gm_i8[%c1] : !pto.ptr<vector<2xi8>, gm>, vector<2xi8>

    // 32-bit total: load via s32, store via b32
    %v_i16 = pto.ldg %gm_i16[%c0] : !pto.ptr<vector<2xi16>, gm> -> vector<2xi16>
    pto.stg %v_i16, %gm_i16[%c1] : !pto.ptr<vector<2xi16>, gm>, vector<2xi16>

    // 64-bit total: load via s64, store via b64
    %v_i32 = pto.ldg %gm_i32[%c0] : !pto.ptr<vector<2xi32>, gm> -> vector<2xi32>
    pto.stg %v_i32, %gm_i32[%c1] : !pto.ptr<vector<2xi32>, gm>, vector<2xi32>

    return
  }
}

// CHECK-LABEL: llvm.func @packed_vector_ldst_kernel_mix_aiv
// CHECK-DAG: llvm.call @llvm.hivm.ldg.cache.s16
// CHECK-DAG: llvm.call @llvm.hivm.stg.cache.b16
// CHECK-DAG: llvm.call @llvm.hivm.ldg.cache.s32
// CHECK-DAG: llvm.call @llvm.hivm.stg.cache.b32
// CHECK-DAG: llvm.call @llvm.hivm.ldg.cache.s64
// CHECK-DAG: llvm.call @llvm.hivm.stg.cache.b64
// 16-bit read: trunc i32->i16 then bitcast to target type
// CHECK-DAG: llvm.bitcast {{.*}} : i16 to !llvm.vec<2 x float8e4m3>
// CHECK-DAG: llvm.bitcast {{.*}} : i16 to !llvm.vec<2 x float8e5m2>
// CHECK-DAG: llvm.bitcast {{.*}} : i16 to !llvm.vec<2 x hifloat8>
// CHECK-DAG: llvm.bitcast {{.*}} : i16 to vector<2xi8>
// 32/64-bit reads: direct bitcast
// CHECK-DAG: llvm.bitcast {{.*}} : i32 to vector<2xi16>
// CHECK-DAG: llvm.bitcast {{.*}} : i64 to vector<2xi32>
