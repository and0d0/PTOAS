// Verifier error: UB binary ops must use UB-backed pointer operands.
// All 7 new ops (vmax/vmin/vand/vor/vxor/vshl/vshr) share the same verify()
// which rejects non-UB memory roles. Tests with GM-backed pointers.
// RUN: not ptoas --pto-arch=a3 --pto-backend=vpto %s 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a3", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @bad_gm_operand(%dst: !pto.ptr<f32, gm>, %src0: !pto.ptr<f32, gm>, %src1: !pto.ptr<f32, gm>) attributes {pto.aicore} {
    %c1 = arith.constant 1 : i64
    %c0 = arith.constant 0 : i64
    // CHECK: requires UB-backed operands
    pto.ub.vmax %dst, %src0, %src1, %c1, %c1, %c1, %c1, %c0, %c0, %c0 : !pto.ptr<f32, gm>, !pto.ptr<f32, gm>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64, i64
    return
  }
}
