// Verify that the standard MLIR inliner runs before VMI layout assignment:
// ordinary private helpers are inlined, while `no_inline` and `pto.simt_entry`
// preserve explicit call boundaries.
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto %s -o - | FileCheck %s

module attributes {pto.kernel_kind = #pto.kernel_kind<vector>, pto.target_arch = "a5"} {
  func.func private @inline_helper(%src: !pto.ptr<f32, ub>,
                                   %dst: !pto.ptr<f32, ub>) {
    %c0 = arith.constant 0 : index
    %c64 = arith.constant 64 : index
    %mask = pto.vmi.create_mask %c64 : index -> !pto.vmi.mask<64xpred>
    %x = pto.vmi.vload %src[%c0]
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<64xf32>
    %sum = pto.vmi.vadd %x, %x
        : !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf32>
        -> !pto.vmi.vreg<64xf32>
    pto.vmi.vstore %sum, %dst[%c0], %mask
        : !pto.vmi.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.vmi.mask<64xpred>
    return
  }

  func.func @kernel(%src: !pto.ptr<f32, ub>, %tmp: !pto.ptr<f32, ub>,
                    %dst: !pto.ptr<f32, ub>) {
    func.call @inline_helper(%src, %tmp)
        : (!pto.ptr<f32, ub>, !pto.ptr<f32, ub>) -> ()
    func.call @kept_helper(%tmp, %dst)
        : (!pto.ptr<f32, ub>, !pto.ptr<f32, ub>) -> ()
    func.call @simt_body() : () -> ()
    return
  }

  func.func private @kept_helper(%src: !pto.ptr<f32, ub>,
                                 %dst: !pto.ptr<f32, ub>)
      attributes {no_inline} {
    %c0 = arith.constant 0 : index
    %c64 = arith.constant 64 : index
    %mask = pto.vmi.create_mask %c64 : index -> !pto.vmi.mask<64xpred>
    %x = pto.vmi.vload %src[%c0]
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<64xf32>
    %sum = pto.vmi.vadd %x, %x
        : !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf32>
        -> !pto.vmi.vreg<64xf32>
    pto.vmi.vstore %sum, %dst[%c0], %mask
        : !pto.vmi.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.vmi.mask<64xpred>
    return
  }

  func.func private @simt_body() attributes {pto.simt_entry} {
    return
  }
}

// CHECK-NOT: func.func private @inline_helper
// CHECK-LABEL: func.func @kernel(
// CHECK: %[[INLINED:.*]] = pto.vadd
// CHECK: pto.vsts %[[INLINED]]
// CHECK: call @kept_helper(
// CHECK: call @simt_body()
// CHECK-LABEL: func.func private @kept_helper(
// CHECK-SAME: attributes {no_inline}
// CHECK-LABEL: func.func private @simt_body()
// CHECK-SAME: attributes {
// CHECK-SAME: no_inline
// CHECK-SAME: pto.simt_entry
